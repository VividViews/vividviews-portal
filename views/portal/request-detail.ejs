<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-client', { user, active: 'dashboard' }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2>View Service Request</h2>
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:13px;color:var(--text-secondary)">Portal &rsaquo; <a href="/portal" style="color:var(--text-secondary);text-decoration:none">My Requests</a> &rsaquo; #<%= String(request.id).padStart(6, '0') %></span>
      <a href="/portal" class="btn btn-secondary btn-sm">← Back</a>
    </div>
  </div>
  <div class="content">

    <!-- Two-column info grid -->
    <div class="detail-grid" style="grid-template-columns:1fr 1fr;margin-bottom:24px">
      <div class="detail-section" style="margin-bottom:0">
        <h3>Ticket Information</h3>
        <div class="detail-row">
          <div class="detail-label">Created</div>
          <div class="detail-value"><%= new Date(request.created_at).toLocaleString() %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Ticket #</div>
          <div class="detail-value" style="font-weight:600;font-family:monospace;color:var(--cyan)"><%= String(request.id).padStart(6, '0') %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Service Type</div>
          <div class="detail-value"><%= request.service_type_name %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Urgency</div>
          <div class="detail-value"><span class="badge badge-<%= request.urgency %>"><%= request.urgency %></span></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Status</div>
          <div class="detail-value"><span class="badge badge-<%= request.status %>"><%= request.status.replace('_', ' ') %></span></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Last Updated</div>
          <div class="detail-value"><%= new Date(request.updated_at).toLocaleString() %></div>
        </div>
      </div>

      <div class="detail-section" style="margin-bottom:0">
        <h3>Description</h3>
        <div class="description-text"><%= request.description %></div>

        <!-- Status Timeline -->
        <h3 style="margin-top:24px">Progress</h3>
        <div style="display:flex;flex-direction:column;gap:12px;margin-top:12px">
          <% var statuses = ['submitted', 'in_review', 'in_progress', 'complete'];
             var currentIdx = statuses.indexOf(request.status);
             statuses.forEach(function(s, i) { %>
            <div style="display:flex;align-items:center;gap:12px">
              <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;
                <%= i <= currentIdx ? 'background:linear-gradient(135deg,#00d4ff,#7c3aed);color:white;box-shadow:0 0 12px rgba(0,212,255,0.3)' : 'background:rgba(255,255,255,0.05);color:var(--text-secondary);border:1px solid var(--card-border)' %>">
                <%= i <= currentIdx ? '✓' : (i + 1) %>
              </div>
              <span style="font-size:14px;font-weight:<%= i === currentIdx ? '600' : '400' %>;color:<%= i <= currentIdx ? 'var(--text)' : 'var(--text-secondary)' %>">
                <%= s.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Rating Section (for completed requests) -->
    <% if (request.status === 'complete') { %>
    <div class="detail-section" style="margin-bottom:24px;border-color:rgba(245,158,11,0.2)">
      <% if (rating) { %>
        <h3>Your Rating</h3>
        <div style="font-size:28px;margin-bottom:8px">
          <% for (let i = 1; i <= 5; i++) { %>
            <span style="color:<%= i <= rating.rating ? '#fbbf24' : 'var(--text-secondary)' %>">★</span>
          <% } %>
        </div>
        <% if (rating.feedback) { %>
          <div style="color:var(--text);font-style:italic">"<%= rating.feedback %>"</div>
        <% } %>
        <div style="font-size:12px;color:var(--text-secondary);margin-top:8px">Thank you for your feedback!</div>
      <% } else { %>
        <h3>⭐ How did we do?</h3>
        <form method="POST" action="/portal/requests/<%= request.id %>/rate">
          <div style="margin-bottom:16px">
            <div id="star-rating" style="font-size:32px;cursor:pointer;user-select:none">
              <% for (let i = 1; i <= 5; i++) { %>
                <span class="star" data-value="<%= i %>" style="color:var(--text-secondary);transition:color 0.1s">★</span>
              <% } %>
            </div>
            <input type="hidden" name="rating" id="rating-value" required>
          </div>
          <div class="form-group">
            <label>Feedback (optional)</label>
            <textarea name="feedback" class="form-control" rows="3" placeholder="Tell us about your experience..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" id="rate-btn" disabled>Submit Rating</button>
        </form>
        <script>
          (function() {
            const stars = document.querySelectorAll('#star-rating .star');
            const input = document.getElementById('rating-value');
            const btn = document.getElementById('rate-btn');
            let selected = 0;
            stars.forEach(star => {
              star.addEventListener('mouseenter', () => {
                const val = parseInt(star.dataset.value);
                stars.forEach((s, i) => { s.style.color = (i + 1) <= val ? '#fbbf24' : 'var(--text-secondary)'; });
              });
              star.addEventListener('click', () => {
                selected = parseInt(star.dataset.value);
                input.value = selected;
                btn.disabled = false;
                stars.forEach((s, i) => { s.style.color = (i + 1) <= selected ? '#fbbf24' : 'var(--text-secondary)'; });
              });
            });
            document.getElementById('star-rating').addEventListener('mouseleave', () => {
              stars.forEach((s, i) => { s.style.color = (i + 1) <= selected ? '#fbbf24' : 'var(--text-secondary)'; });
            });
          })();
        </script>
      <% } %>
    </div>
    <% } %>

    <!-- Action buttons row -->
    <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap">
      <a href="#section-comment" class="btn btn-primary btn-sm">💬 Add Comment</a>
      <a href="#section-upload" class="btn btn-secondary btn-sm">📎 Upload File</a>
    </div>

    <!-- Activity Log -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header"><h3>Activity Log</h3></div>
      <% if (comments.length === 0) { %>
        <div class="empty-state" style="padding:24px"><p>No activity yet.</p></div>
      <% } else { %>
      <div style="padding:16px;display:flex;flex-direction:column;gap:12px">
        <% comments.forEach(c => {
          const isAdmin = c.author_role === 'admin';
          const borderColor = isAdmin ? '#00d4ff' : '#10b981';
          const labelColor = isAdmin ? '#00d4ff' : '#10b981';
          const label = isAdmin ? 'Vivid Views' : 'You';
          let bgColor = 'rgba(255,255,255,0.02)';
          if (c.comment_type === 'status_change') bgColor = 'rgba(0,212,255,0.04)';
          else if (c.comment_type === 'file_upload') bgColor = 'rgba(16,185,129,0.04)';
          else if (c.comment_type === 'system') bgColor = 'rgba(255,255,255,0.01)';
        %>
        <div style="border-left:3px solid <%= borderColor %>;padding:12px 16px;background:<%= bgColor %>;border-radius:0 8px 8px 0">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
            <strong style="color:<%= labelColor %>;font-size:13px"><%= label %></strong>
            <span style="font-size:12px;color:var(--text-secondary)"><%= new Date(c.created_at).toLocaleString() %></span>
          </div>
          <div style="color:var(--text);<%= c.comment_type === 'system' ? 'font-style:italic;opacity:0.7;' : '' %>"><%= c.comment %></div>
          <% if (c.comment_type !== 'comment') { %>
            <span class="badge badge-<%= c.comment_type === 'status_change' ? 'in_progress' : c.comment_type === 'file_upload' ? 'complete' : 'submitted' %>" style="margin-top:6px;display:inline-block"><%= c.comment_type.replace('_', ' ') %></span>
          <% } %>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Attachments -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header"><h3>Attachments (<%= attachments.length %>)</h3></div>
      <% if (attachments.length === 0) { %>
        <div class="empty-state" style="padding:24px"><p>No files attached.</p></div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Type</th>
            <th>Uploaded</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% attachments.forEach(a => { %>
          <tr>
            <td><a href="/uploads/<%= a.filename %>" target="_blank">📎 <%= a.original_name %></a></td>
            <td style="color:var(--text-secondary)"><%= a.mimetype %></td>
            <td style="color:var(--text-secondary)"><%= new Date(a.created_at).toLocaleString() %></td>
            <td><a href="/uploads/<%= a.filename %>" download class="btn btn-secondary btn-sm">Download</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Forms section -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
      <!-- Add Comment -->
      <div class="detail-section" id="section-comment" style="margin-bottom:0">
        <h3>💬 Add Comment</h3>
        <form method="POST" action="/portal/requests/<%= request.id %>/comment">
          <div class="form-group">
            <textarea name="comment" class="form-control" rows="4" placeholder="Write a comment..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">Post Comment</button>
        </form>
      </div>

      <!-- Upload File -->
      <div class="detail-section" id="section-upload" style="margin-bottom:0">
        <h3>📎 Upload File</h3>
        <form method="POST" action="/portal/requests/<%= request.id %>/upload" enctype="multipart/form-data">
          <div class="form-group">
            <input type="file" name="file" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-secondary" style="width:100%">Upload</button>
        </form>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/foot') %>
