<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-client', { user, active: 'new-request' }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2>New Service Request</h2>
    <a href="/portal" class="btn btn-secondary btn-sm">← Back</a>
  </div>
  <div class="content">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="detail-section" style="max-width:700px">
      <h3>Submit a Request</h3>
      <form method="POST" action="/portal/requests" enctype="multipart/form-data">

        <% if (userSite) { %>
        <div class="form-group">
          <label>Site</label>
          <div style="padding:10px 14px;background:rgba(0,212,255,0.06);border:1px solid rgba(0,212,255,0.15);border-radius:8px;font-size:14px;color:var(--cyan)">
            📍 <%= userSite.site_name %>
            <% if (userSite.address) { %>
              <span style="color:var(--text-secondary);margin-left:8px"><%= userSite.address %></span>
            <% } %>
          </div>
        </div>
        <% } %>

        <div class="form-group">
          <label>Service Type</label>
          <select name="service_type_id" class="form-control" required>
            <option value="">Select a service...</option>
            <% serviceTypes.forEach(st => { %>
              <option value="<%= st.id %>"><%= st.name %></option>
            <% }) %>
          </select>
          <small style="color:var(--text-secondary);font-size:12px;margin-top:4px;display:block">Urgency is automatically set based on the service type.</small>
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="description" class="form-control" rows="6" required placeholder="Describe what you need..."></textarea>
        </div>
        <div class="form-group">
          <label>Attachments (optional, max 5 files)</label>
          <input type="file" name="files" class="form-control" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.zip">
        </div>

        <!-- Emergency Checkbox -->
        <div class="form-group" style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);border-radius:8px;padding:16px">
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;text-transform:none;letter-spacing:0;font-size:14px;color:var(--text);margin-bottom:0">
            <input type="checkbox" name="is_emergency" value="on" style="width:18px;height:18px;accent-color:#ef4444">
            <span>⚠️ <strong>Emergency Request</strong></span>
          </label>
          <p style="color:var(--text-secondary);font-size:13px;margin-top:8px;line-height:1.6;padding-left:28px">
            Emergency requests outside business hours incur additional fees. A base fee plus hourly labor rate will apply. Your request will require admin approval before dispatch.
          </p>
        </div>

        <button type="submit" class="btn btn-primary">Submit Request</button>
        <a href="/portal" class="btn btn-secondary" style="margin-left:8px">Cancel</a>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
