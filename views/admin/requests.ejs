<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'requests', stats: { pendingEmergencies: 0 } }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2>All Requests</h2>
    <div></div>
  </div>
  <div class="content">
    <div class="card">
      <form class="filter-bar" method="GET" action="/admin/requests">
        <select name="status" onchange="this.form.submit()">
          <option value="">All Statuses</option>
          <option value="submitted" <%= filters.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
          <option value="in_review" <%= filters.status === 'in_review' ? 'selected' : '' %>>In Review</option>
          <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
          <option value="complete" <%= filters.status === 'complete' ? 'selected' : '' %>>Complete</option>
        </select>
        <select name="urgency" onchange="this.form.submit()">
          <option value="">All Urgencies</option>
          <option value="low" <%= filters.urgency === 'low' ? 'selected' : '' %>>Low</option>
          <option value="medium" <%= filters.urgency === 'medium' ? 'selected' : '' %>>Medium</option>
          <option value="high" <%= filters.urgency === 'high' ? 'selected' : '' %>>High</option>
          <option value="urgent" <%= filters.urgency === 'urgent' ? 'selected' : '' %>>Urgent</option>
        </select>
        <select name="client_id" onchange="this.form.submit()">
          <option value="">All Clients</option>
          <% clients.forEach(c => { %>
            <option value="<%= c.id %>" <%= filters.client_id == c.id ? 'selected' : '' %>><%= c.company_name %></option>
          <% }) %>
        </select>
        <select name="site_id" onchange="this.form.submit()">
          <option value="">All Sites</option>
          <% allSites.forEach(s => { %>
            <option value="<%= s.id %>" <%= filters.site_id == s.id ? 'selected' : '' %>><%= s.site_name %></option>
          <% }) %>
        </select>
      </form>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Client</th>
            <th>Site</th>
            <th>Service</th>
            <th>Urgency</th>
            <th>Status</th>
            <th>Days Open</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% requests.forEach(r => {
            const daysOpen = Math.floor((Date.now() - new Date(r.created_at).getTime()) / 86400000);
            const isEmergency = r.is_emergency === true || r.is_emergency === 1;
          %>
          <tr style="cursor:pointer;<%= isEmergency ? 'box-shadow:inset 0 0 20px rgba(239,68,68,0.06);' : '' %>" onclick="window.location='/admin/requests/<%= r.id %>'">
            <td>
              <a href="/admin/requests/<%= r.id %>">#<%= r.id %></a>
              <% if (isEmergency) { %>
                <span class="badge badge-urgent" style="font-size:9px;padding:1px 5px;margin-left:4px">🚨</span>
              <% } %>
            </td>
            <td><%= r.company_name %></td>
            <td style="color:var(--text-secondary)"><%= r.site_name || '—' %></td>
            <td><%= r.service_type_name %></td>
            <td><span class="badge badge-<%= r.urgency %>"><%= r.urgency %></span></td>
            <td><span class="badge badge-<%= r.status %>"><%= r.status.replace('_', ' ') %></span></td>
            <td><%= r.status === 'complete' ? '—' : daysOpen + 'd' %></td>
            <td style="color:var(--text-secondary)"><%= new Date(r.created_at).toLocaleDateString() %></td>
          </tr>
          <% }) %>
          <% if (requests.length === 0) { %>
          <tr><td colspan="8" style="text-align:center;padding:32px;color:var(--text-secondary)">No requests match your filters</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
