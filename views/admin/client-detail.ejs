<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'clients' }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2><%= client ? client.company_name : 'New Client' %></h2>
    <div>
      <% if (client) { %>
        <button class="btn btn-danger btn-sm" onclick="deleteResource('/admin/clients/<%= client.id %>', '/admin/clients')">Delete Client</button>
      <% } %>
    </div>
  </div>
  <div class="content">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (!client) { %>
      <!-- Create new client form -->
      <div class="detail-section" style="max-width:600px">
        <h3>Create New Client</h3>
        <form method="POST" action="/admin/clients">
          <div class="form-group">
            <label>Company Name</label>
            <input type="text" name="company_name" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Contact Name</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" class="form-control" required minlength="6">
          </div>
          <div class="form-group">
            <label>Client Type</label>
            <select name="client_type" class="form-control">
              <option value="standard">Standard</option>
              <option value="carwash">Car Wash</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary">Create Client</button>
          <a href="/admin/clients" class="btn btn-secondary" style="margin-left:8px">Cancel</a>
        </form>
      </div>
    <% } else { %>
      <div class="detail-grid">
        <div>
          <!-- Client Info -->
          <div class="detail-section">
            <h3>Client Information</h3>
            <div class="detail-row">
              <div class="detail-label">Company</div>
              <div class="detail-value"><%= client.company_name %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label">Contact</div>
              <div class="detail-value"><%= clientUser.name %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label">Email</div>
              <div class="detail-value"><%= clientUser.email %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label">Type</div>
              <div class="detail-value"><span class="badge" style="background:<%= client.client_type === 'carwash' ? 'var(--blue)' : 'var(--gray-300)' %>;color:<%= client.client_type === 'carwash' ? 'white' : 'var(--gray-700)' %>"><%= client.client_type === 'carwash' ? 'Car Wash' : 'Standard' %></span></div>
            </div>
            <div class="detail-row">
              <div class="detail-label">Joined</div>
              <div class="detail-value"><%= new Date(client.created_at).toLocaleDateString() %></div>
            </div>
          </div>

          <!-- Requests -->
          <div class="card">
            <div class="card-header">
              <h3>Service Requests (<%= requests.length %>)</h3>
            </div>
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Service</th>
                  <th>Urgency</th>
                  <th>Status</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% requests.forEach(r => { %>
                <tr style="cursor:pointer" onclick="window.location='/admin/requests/<%= r.id %>'">
                  <td><a href="/admin/requests/<%= r.id %>">#<%= r.id %></a></td>
                  <td><%= r.service_type_name %></td>
                  <td><span class="badge badge-<%= r.urgency %>"><%= r.urgency %></span></td>
                  <td><span class="badge badge-<%= r.status %>"><%= r.status.replace('_', ' ') %></span></td>
                  <td><%= new Date(r.created_at).toLocaleDateString() %></td>
                </tr>
                <% }) %>
                <% if (requests.length === 0) { %>
                <tr><td colspan="5" style="text-align:center;padding:24px;color:#94a3b8">No requests yet</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <!-- Service Types -->
          <div class="detail-section">
            <h3>Service Types</h3>
            <div style="margin-bottom: 16px;">
              <% serviceTypes.forEach(st => { %>
                <span class="tag">
                  <%= st.name %>
                  <button onclick="deleteResource('/admin/clients/<%= client.id %>/service-types/<%= st.id %>', '/admin/clients/<%= client.id %>')" title="Remove">&times;</button>
                </span>
              <% }) %>
              <% if (serviceTypes.length === 0) { %>
                <p style="color:var(--gray-400);font-size:14px">No service types assigned</p>
              <% } %>
            </div>
            <form method="POST" action="/admin/clients/<%= client.id %>/service-types" class="inline-form">
              <input type="text" name="name" placeholder="Add service type..." required>
              <button type="submit" class="btn btn-primary btn-sm">Add</button>
            </form>
          </div>

          <!-- Car Wash Brands & Sites -->
          <div class="detail-section" style="margin-top:24px">
            <h3>🚗 Car Wash Brands & Sites</h3>
            <% if (!brands || brands.length === 0) { %>
              <p style="color:var(--gray-400);font-size:14px;margin-bottom:12px">No brands yet</p>
            <% } else { %>
              <% brands.forEach(brand => { %>
                <div style="border:1px solid var(--gray-200);border-radius:8px;padding:16px;margin-bottom:16px">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                    <h4 style="margin:0;color:var(--navy)"><%= brand.brand_name %></h4>
                    <button class="btn btn-danger btn-sm" onclick="deleteResource('/admin/clients/<%= client.id %>/brands/<%= brand.id %>', '/admin/clients/<%= client.id %>')">Delete Brand</button>
                  </div>
                  <% if (brand.sites && brand.sites.length > 0) { %>
                  <table style="margin-bottom:12px">
                    <thead>
                      <tr>
                        <th>Site Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% brand.sites.forEach(site => { %>
                      <tr>
                        <td><%= site.site_name %></td>
                        <td><%= site.address || '—' %></td>
                        <td><%= site.city || '—' %></td>
                        <td><%= site.state || '—' %></td>
                        <td><span class="badge badge-<%= site.status === 'active' ? 'complete' : 'submitted' %>"><%= site.status %></span></td>
                        <td style="white-space:nowrap">
                          <form method="POST" action="/admin/clients/<%= client.id %>/brands/<%= brand.id %>/sites/<%= site.id %>/status" style="display:inline">
                            <button type="submit" class="btn btn-secondary btn-sm" title="Toggle status"><%= site.status === 'active' ? '⏸ Deactivate' : '▶ Activate' %></button>
                          </form>
                          <button class="btn btn-danger btn-sm" onclick="deleteResource('/admin/clients/<%= client.id %>/brands/<%= brand.id %>/sites/<%= site.id %>', '/admin/clients/<%= client.id %>')">Delete</button>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                  <% } else { %>
                    <p style="color:var(--gray-400);font-size:13px;margin-bottom:12px">No sites yet</p>
                  <% } %>
                  <details style="margin-top:8px">
                    <summary style="cursor:pointer;color:var(--blue);font-size:14px">+ Add Site</summary>
                    <form method="POST" action="/admin/clients/<%= client.id %>/brands/<%= brand.id %>/sites" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px">
                      <input type="text" name="site_name" placeholder="Site name" required style="flex:1;min-width:140px">
                      <input type="text" name="address" placeholder="Address" style="flex:1;min-width:140px">
                      <input type="text" name="city" placeholder="City" style="width:120px">
                      <input type="text" name="state" placeholder="State" style="width:60px">
                      <button type="submit" class="btn btn-primary btn-sm">Add Site</button>
                    </form>
                  </details>
                </div>
              <% }) %>
            <% } %>
            <details style="margin-top:8px">
              <summary style="cursor:pointer;color:var(--blue);font-weight:600">+ Add Brand</summary>
              <form method="POST" action="/admin/clients/<%= client.id %>/brands" class="inline-form" style="margin-top:8px">
                <input type="text" name="brand_name" placeholder="Brand name..." required>
                <button type="submit" class="btn btn-primary btn-sm">Add Brand</button>
              </form>
            </details>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/foot') %>
