<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'employees', stats: { pendingEmergencies: 0 } }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2><%= employee ? employee.name : 'New Employee' %></h2>
    <div>
      <% if (employee) { %>
        <button class="btn btn-danger btn-sm" onclick="deleteResource('/admin/employees/<%= employee.id %>', '/admin/employees')">Delete</button>
      <% } %>
      <a href="/admin/employees" class="btn btn-secondary btn-sm">← Back</a>
    </div>
  </div>
  <div class="content">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (!employee) { %>
      <!-- Create Form -->
      <div class="detail-section" style="max-width:600px">
        <h3>Create New Employee</h3>
        <form method="POST" action="/admin/employees">
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" class="form-control" required minlength="6">
          </div>
          <div class="form-group">
            <label>Role</label>
            <input type="text" name="role_name" class="form-control" value="Technician" required>
          </div>
          <div class="form-group">
            <label>Hourly Rate ($)</label>
            <input type="number" name="hourly_rate" class="form-control" step="0.01" min="0" value="0">
          </div>
          <button type="submit" class="btn btn-primary">Create Employee</button>
          <a href="/admin/employees" class="btn btn-secondary" style="margin-left:8px">Cancel</a>
        </form>
      </div>
    <% } else { %>
      <div class="detail-grid">
        <div>
          <!-- Edit Form -->
          <div class="detail-section">
            <h3>Employee Information</h3>
            <form method="POST" action="/admin/employees/<%= employee.id %>/edit">
              <div style="display:flex;gap:12px;margin-bottom:12px">
                <div class="form-group" style="flex:1;margin-bottom:0">
                  <label>Name</label>
                  <input type="text" name="name" class="form-control" value="<%= employee.name %>" required>
                </div>
                <div class="form-group" style="flex:1;margin-bottom:0">
                  <label>Role</label>
                  <input type="text" name="role_name" class="form-control" value="<%= employee.role_name %>" required>
                </div>
                <div class="form-group" style="width:120px;margin-bottom:0">
                  <label>Hourly Rate ($)</label>
                  <input type="number" name="hourly_rate" class="form-control" step="0.01" min="0" value="<%= parseFloat(employee.hourly_rate).toFixed(2) %>">
                </div>
              </div>
              <button type="submit" class="btn btn-primary btn-sm">Save Changes</button>
            </form>

            <div style="display:flex;gap:8px;margin-top:16px;padding-top:16px;border-top:1px solid var(--card-border)">
              <div class="detail-row" style="border:none;padding:0">
                <div class="detail-label">Email</div>
                <div class="detail-value"><%= employee.email %></div>
              </div>
              <div class="detail-row" style="border:none;padding:0;margin-left:32px">
                <div class="detail-label">Status</div>
                <div class="detail-value">
                  <span class="badge" style="background:<%= employee.status === 'active' ? 'rgba(16,185,129,0.2)' : employee.status === 'pending' ? 'rgba(245,158,11,0.2)' : 'rgba(100,116,139,0.2)' %>;color:<%= employee.status === 'active' ? '#10b981' : employee.status === 'pending' ? '#fbbf24' : '#94a3b8' %>"><%= employee.status %></span>
                </div>
              </div>
            </div>

            <div style="display:flex;gap:8px;margin-top:12px">
              <% if (employee.status !== 'active') { %>
                <form method="POST" action="/admin/employees/<%= employee.id %>/approve">
                  <button type="submit" class="btn btn-sm" style="background:rgba(16,185,129,0.15);color:#10b981;border:1px solid rgba(16,185,129,0.3)">✅ Approve</button>
                </form>
              <% } %>
              <% if (employee.status !== 'inactive') { %>
                <form method="POST" action="/admin/employees/<%= employee.id %>/deactivate">
                  <button type="submit" class="btn btn-sm" style="background:rgba(100,116,139,0.15);color:#94a3b8;border:1px solid rgba(100,116,139,0.3)">⏸ Deactivate</button>
                </form>
              <% } %>
            </div>
          </div>

          <!-- Assignments -->
          <div class="detail-section">
            <h3>Assigned Clients / Sites</h3>
            <% if (assignments.length > 0) { %>
            <table>
              <thead><tr><th>Client</th><th>Site</th><th>Actions</th></tr></thead>
              <tbody>
                <% assignments.forEach(a => { %>
                <tr>
                  <td><%= a.company_name %></td>
                  <td><%= a.site_name || 'All sites' %></td>
                  <td><button class="btn btn-danger btn-sm" onclick="deleteResource('/admin/employees/<%= employee.id %>/assign/<%= a.id %>', '/admin/employees/<%= employee.id %>')">Remove</button></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
              <p style="color:var(--text-secondary);font-size:14px;margin-bottom:12px">No assignments yet</p>
            <% } %>

            <details style="margin-top:12px">
              <summary style="cursor:pointer;color:var(--cyan);font-weight:600">+ Add Assignment</summary>
              <form method="POST" action="/admin/employees/<%= employee.id %>/assign" style="display:flex;gap:8px;margin-top:8px;align-items:flex-end">
                <div class="form-group" style="margin-bottom:0;flex:1">
                  <label>Client</label>
                  <select name="client_id" class="form-control" required>
                    <option value="">Select client...</option>
                    <% clients.forEach(c => { %>
                      <option value="<%= c.id %>"><%= c.company_name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-group" style="margin-bottom:0;flex:1">
                  <label>Site (optional)</label>
                  <select name="site_id" class="form-control">
                    <option value="">All sites</option>
                  </select>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Assign</button>
              </form>
            </details>
          </div>

          <!-- Open Requests -->
          <div class="card">
            <div class="card-header"><h3>Open Requests</h3></div>
            <table>
              <thead><tr><th>ID</th><th>Client</th><th>Site</th><th>Service</th><th>Status</th></tr></thead>
              <tbody>
                <% openRequests.forEach(r => { %>
                <tr style="cursor:pointer" onclick="window.location='/admin/requests/<%= r.id %>'">
                  <td><a href="/admin/requests/<%= r.id %>">#<%= r.id %></a></td>
                  <td><%= r.company_name %></td>
                  <td><%= r.site_name || '—' %></td>
                  <td><%= r.service_type_name %></td>
                  <td><span class="badge badge-<%= r.status %>"><%= r.status.replace('_',' ') %></span></td>
                </tr>
                <% }) %>
                <% if (openRequests.length === 0) { %>
                <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-secondary)">No open requests</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <!-- Time Logs -->
          <div class="detail-section">
            <h3>⏱️ Time Logs</h3>
            <% if (timeLogs.length > 0) { %>
            <table>
              <thead><tr><th>Request</th><th>Clocked In</th><th>Clocked Out</th><th>Total</th></tr></thead>
              <tbody>
                <% timeLogs.forEach(tl => { %>
                <tr>
                  <td><a href="/admin/requests/<%= tl.service_request_id %>">#<%= tl.service_request_id %></a></td>
                  <td style="font-size:13px"><%= new Date(tl.clocked_in_at).toLocaleString() %></td>
                  <td style="font-size:13px"><%= tl.clocked_out_at ? new Date(tl.clocked_out_at).toLocaleString() : '🟢 Active' %></td>
                  <td><%= tl.total_minutes ? Math.floor(tl.total_minutes / 60) + 'h ' + (tl.total_minutes % 60) + 'm' : '—' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
              <p style="color:var(--text-secondary);font-size:14px">No time logs yet</p>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/foot') %>
