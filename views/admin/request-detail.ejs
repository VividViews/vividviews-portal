<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'requests', stats: { pendingEmergencies: 0 } }) %>

<%
  const daysOpen = Math.floor((Date.now() - new Date(request.created_at).getTime()) / 86400000);
  const isEmergency = request.is_emergency === true || request.is_emergency === 1;
%>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2 style="display:flex;align-items:center;gap:12px">
      View Service Request
      <% if (request.status !== 'complete') { %>
        <span class="badge" style="background:rgba(0,212,255,0.15);color:#00d4ff;font-size:12px"><%= daysOpen %>d open</span>
      <% } %>
      <% if (isEmergency) { %>
        <span class="badge badge-urgent">🚨 Emergency</span>
      <% } %>
    </h2>
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:13px;color:var(--text-secondary)">Admin &rsaquo; <a href="/admin/requests" style="color:var(--text-secondary);text-decoration:none">Requests</a> &rsaquo; #<%= String(request.id).padStart(6, '0') %></span>
      <a href="/admin/requests" class="btn btn-secondary btn-sm">← Back</a>
    </div>
  </div>
  <div class="content">

    <!-- Two-column info grid -->
    <div class="detail-grid" style="grid-template-columns:1fr 1fr;margin-bottom:24px">
      <div class="detail-section" style="margin-bottom:0">
        <h3>Ticket Information</h3>
        <div class="detail-row">
          <div class="detail-label">Created</div>
          <div class="detail-value"><%= new Date(request.created_at).toLocaleString() %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Ticket #</div>
          <div class="detail-value" style="font-weight:600;font-family:monospace;color:var(--cyan)"><%= String(request.id).padStart(6, '0') %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Client</div>
          <div class="detail-value"><a href="/admin/clients/<%= request.client_id %>" style="color:var(--cyan);text-decoration:none"><%= request.company_name %></a></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Contact</div>
          <div class="detail-value"><%= request.contact_name %></div>
        </div>
        <% if (request.site_name) { %>
        <div class="detail-row">
          <div class="detail-label">Site</div>
          <div class="detail-value">
            <strong><%= request.site_name %></strong>
            <% if (request.site_address) { %>
              <br><span style="color:var(--text-secondary);font-size:13px"><%= request.site_address %><%= request.site_city ? ', ' + request.site_city : '' %><%= request.site_state ? ' ' + request.site_state : '' %></span>
            <% } %>
          </div>
        </div>
        <% } %>
        <div class="detail-row">
          <div class="detail-label">Service Type</div>
          <div class="detail-value"><%= request.service_type_name %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Urgency</div>
          <div class="detail-value"><span class="badge badge-<%= request.urgency %>"><%= request.urgency %></span></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Status</div>
          <div class="detail-value"><span class="badge badge-<%= request.status %>"><%= request.status.replace('_', ' ') %></span></div>
        </div>
        <% if (isEmergency && emergency) { %>
        <div class="detail-row">
          <div class="detail-label">Emergency</div>
          <div class="detail-value">
            <span class="badge badge-urgent"><%= emergency.status %></span>
            <% if (emergency.base_fee) { %>
              <span style="margin-left:8px;color:var(--text-secondary)">Base fee: $<%= parseFloat(emergency.base_fee).toFixed(2) %></span>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>

      <div class="detail-section" style="margin-bottom:0">
        <h3>Description</h3>
        <div class="description-text" style="margin-bottom:20px"><%= request.description %></div>
        <h3 style="margin-top:16px">Admin Notes</h3>
        <div class="description-text" style="color:<%= request.admin_notes ? 'var(--text)' : 'var(--text-secondary)' %>"><%= request.admin_notes || 'None' %></div>

        <% if (rating) { %>
        <div style="margin-top:20px;padding:16px;background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.15);border-radius:8px">
          <h3 style="color:#fbbf24;margin-bottom:8px">Client Rating</h3>
          <div style="font-size:20px;margin-bottom:4px">
            <% for (let i = 1; i <= 5; i++) { %>
              <span style="color:<%= i <= rating.rating ? '#fbbf24' : 'var(--text-secondary)' %>">★</span>
            <% } %>
            <span style="font-size:14px;color:var(--text-secondary);margin-left:8px"><%= rating.rating %>/5</span>
          </div>
          <% if (rating.feedback) { %>
            <div style="color:var(--text);font-style:italic;font-size:14px">"<%= rating.feedback %>"</div>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Action buttons row -->
    <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap">
      <a href="#section-comment" class="btn btn-primary btn-sm">💬 Add Comment</a>
      <a href="#section-upload" class="btn btn-secondary btn-sm">📎 Upload File</a>
      <a href="#section-status" class="btn btn-sm" style="background:rgba(16,185,129,0.15);color:#10b981;border:1px solid rgba(16,185,129,0.3)">🔄 Update Status</a>
      <form method="POST" action="/admin/requests/<%= request.id %>/delete" onsubmit="return confirm('⚠️ Delete this request and all related data? This cannot be undone.')">
        <button type="submit" class="btn btn-danger btn-sm">🗑 Delete Request</button>
      </form>
    </div>

    <!-- Activity Log -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header"><h3>Activity Log</h3></div>
      <% if (comments.length === 0) { %>
        <div class="empty-state" style="padding:24px"><p>No activity yet.</p></div>
      <% } else { %>
      <div style="padding:16px;display:flex;flex-direction:column;gap:12px">
        <% comments.forEach(c => {
          const isAdmin = c.author_role === 'admin';
          const isEmp = c.author_role === 'employee';
          const borderColor = isAdmin ? '#00d4ff' : isEmp ? '#a78bfa' : '#7c3aed';
          const labelColor = isAdmin ? '#00d4ff' : isEmp ? '#a78bfa' : '#a78bfa';
          const label = isAdmin ? 'Admin (You)' : isEmp ? c.author_name + ' (Employee)' : c.author_name;
          let bgColor = 'rgba(255,255,255,0.02)';
          if (c.comment_type === 'status_change') bgColor = 'rgba(0,212,255,0.04)';
          else if (c.comment_type === 'file_upload') bgColor = 'rgba(16,185,129,0.04)';
          else if (c.comment_type === 'system') bgColor = 'rgba(255,255,255,0.01)';
        %>
        <div style="border-left:3px solid <%= borderColor %>;padding:12px 16px;background:<%= bgColor %>;border-radius:0 8px 8px 0">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
            <strong style="color:<%= labelColor %>;font-size:13px"><%= label %></strong>
            <span style="font-size:12px;color:var(--text-secondary)"><%= new Date(c.created_at).toLocaleString() %></span>
          </div>
          <div style="color:var(--text);<%= c.comment_type === 'system' ? 'font-style:italic;opacity:0.7;' : '' %>"><%= c.comment %></div>
          <% if (c.comment_type !== 'comment') { %>
            <span class="badge badge-<%= c.comment_type === 'status_change' ? 'in_progress' : c.comment_type === 'file_upload' ? 'complete' : 'submitted' %>" style="margin-top:6px;display:inline-block"><%= c.comment_type.replace('_', ' ') %></span>
          <% } %>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Attachments -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header"><h3>Attachments (<%= attachments.length %>)</h3></div>
      <% if (attachments.length === 0) { %>
        <div class="empty-state" style="padding:24px"><p>No files attached.</p></div>
      <% } else { %>
      <table>
        <thead><tr><th>File</th><th>Type</th><th>Uploaded</th><th>Action</th></tr></thead>
        <tbody>
          <% attachments.forEach(a => { %>
          <tr>
            <td><a href="/uploads/<%= a.filename %>" target="_blank">📎 <%= a.original_name %></a></td>
            <td style="color:var(--text-secondary)"><%= a.mimetype %></td>
            <td style="color:var(--text-secondary)"><%= new Date(a.created_at).toLocaleString() %></td>
            <td><a href="/uploads/<%= a.filename %>" download class="btn btn-secondary btn-sm">Download</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Forms section -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px">
      <div class="detail-section" id="section-comment" style="margin-bottom:0">
        <h3>💬 Add Comment</h3>
        <form method="POST" action="/admin/requests/<%= request.id %>/comment">
          <div class="form-group">
            <textarea name="comment" class="form-control" rows="4" placeholder="Write a comment..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">Post Comment</button>
        </form>
      </div>
      <div class="detail-section" id="section-upload" style="margin-bottom:0">
        <h3>📎 Upload File</h3>
        <form method="POST" action="/admin/requests/<%= request.id %>/upload" enctype="multipart/form-data">
          <div class="form-group">
            <input type="file" name="file" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-secondary" style="width:100%">Upload</button>
        </form>
      </div>
      <div class="detail-section" id="section-status" style="margin-bottom:0">
        <h3>🔄 Update Status</h3>
        <form method="POST" action="/admin/requests/<%= request.id %>/status">
          <div class="form-group">
            <label>Status</label>
            <select name="status" class="form-control">
              <option value="submitted" <%= request.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
              <option value="in_review" <%= request.status === 'in_review' ? 'selected' : '' %>>In Review</option>
              <option value="in_progress" <%= request.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
              <option value="complete" <%= request.status === 'complete' ? 'selected' : '' %>>Complete</option>
            </select>
          </div>
          <div class="form-group">
            <label>Admin Notes</label>
            <textarea name="admin_notes" class="form-control" rows="3"><%= request.admin_notes || '' %></textarea>
          </div>
          <button type="submit" class="btn btn-sm" style="background:rgba(16,185,129,0.15);color:#10b981;border:1px solid rgba(16,185,129,0.3);width:100%;padding:10px 20px">Update Status</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
