<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'requests' }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2>View Service Request</h2>
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:13px;color:var(--gray-400)">Admin &rsaquo; <a href="/admin/requests" style="color:var(--gray-500);text-decoration:none">Service Requests</a> &rsaquo; Ticket #<%= String(request.id).padStart(6, '0') %></span>
      <a href="/admin/requests" class="btn btn-secondary btn-sm">← Back</a>
    </div>
  </div>
  <div class="content">

    <!-- Two-column info grid -->
    <div class="detail-grid" style="grid-template-columns:1fr 1fr;margin-bottom:24px">
      <div class="detail-section" style="margin-bottom:0">
        <h3>Ticket Information</h3>
        <div class="detail-row">
          <div class="detail-label">Created</div>
          <div class="detail-value"><%= new Date(request.created_at).toLocaleString() %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Ticket #</div>
          <div class="detail-value" style="font-weight:600;font-family:monospace"><%= String(request.id).padStart(6, '0') %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Client</div>
          <div class="detail-value"><%= request.company_name %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Contact</div>
          <div class="detail-value"><%= request.contact_name %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Service Type</div>
          <div class="detail-value"><%= request.service_type_name %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Urgency</div>
          <div class="detail-value"><span class="badge badge-<%= request.urgency %>"><%= request.urgency %></span></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Status</div>
          <div class="detail-value"><span class="badge badge-<%= request.status %>"><%= request.status.replace('_', ' ') %></span></div>
        </div>
      </div>

      <div class="detail-section" style="margin-bottom:0">
        <h3>Description</h3>
        <div class="description-text" style="margin-bottom:20px"><%= request.description %></div>
        <h3 style="margin-top:16px">Admin Notes</h3>
        <div class="description-text" style="color:<%= request.admin_notes ? 'var(--gray-700)' : 'var(--gray-400)' %>"><%= request.admin_notes || 'None' %></div>
      </div>
    </div>

    <!-- Action buttons row -->
    <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap">
      <a href="#section-comment" class="btn btn-primary btn-sm">💬 Add Comment</a>
      <a href="#section-upload" class="btn btn-secondary btn-sm">📎 Upload File</a>
      <a href="#section-status" class="btn btn-sm" style="background:var(--green);color:white">🔄 Update Status</a>
    </div>

    <!-- Activity Log -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header"><h3>Activity Log</h3></div>
      <% if (comments.length === 0) { %>
        <div class="empty-state" style="padding:24px"><p>No activity yet.</p></div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>User</th>
            <th>Comment</th>
            <th>Type</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% comments.forEach(c => {
            let rowStyle = '';
            if (c.comment_type === 'system') rowStyle = 'background:#f8fafc;font-style:italic;';
            else if (c.comment_type === 'status_change') rowStyle = 'background:#eff6ff;';
            else if (c.comment_type === 'file_upload') rowStyle = 'background:#f0fdf4;';
          %>
          <tr style="<%= rowStyle %>">
            <td style="font-weight:600;white-space:nowrap"><%= c.author_name %></td>
            <td><%= c.comment %></td>
            <td><span class="badge badge-<%= c.comment_type === 'system' ? 'submitted' : c.comment_type === 'status_change' ? 'in_progress' : c.comment_type === 'file_upload' ? 'complete' : 'in_review' %>"><%= c.comment_type.replace('_', ' ') %></span></td>
            <td style="white-space:nowrap"><%= new Date(c.created_at).toLocaleString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Attachments -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header"><h3>Attachments (<%= attachments.length %>)</h3></div>
      <% if (attachments.length === 0) { %>
        <div class="empty-state" style="padding:24px"><p>No files attached.</p></div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Type</th>
            <th>Uploaded</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% attachments.forEach(a => { %>
          <tr>
            <td><a href="/uploads/<%= a.filename %>" target="_blank">📎 <%= a.original_name %></a></td>
            <td><%= a.mimetype %></td>
            <td><%= new Date(a.created_at).toLocaleString() %></td>
            <td><a href="/uploads/<%= a.filename %>" download class="btn btn-secondary btn-sm">Download</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Forms section -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px">
      <!-- Add Comment -->
      <div class="detail-section" id="section-comment" style="margin-bottom:0">
        <h3>💬 Add Comment</h3>
        <form method="POST" action="/admin/requests/<%= request.id %>/comment">
          <div class="form-group">
            <textarea name="comment" class="form-control" rows="4" placeholder="Write a comment..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">Post Comment</button>
        </form>
      </div>

      <!-- Upload File -->
      <div class="detail-section" id="section-upload" style="margin-bottom:0">
        <h3>📎 Upload File</h3>
        <form method="POST" action="/admin/requests/<%= request.id %>/upload" enctype="multipart/form-data">
          <div class="form-group">
            <input type="file" name="file" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-secondary" style="width:100%">Upload</button>
        </form>
      </div>

      <!-- Update Status -->
      <div class="detail-section" id="section-status" style="margin-bottom:0">
        <h3>🔄 Update Status</h3>
        <form method="POST" action="/admin/requests/<%= request.id %>/status">
          <div class="form-group">
            <label>Status</label>
            <select name="status" class="form-control">
              <option value="submitted" <%= request.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
              <option value="in_review" <%= request.status === 'in_review' ? 'selected' : '' %>>In Review</option>
              <option value="in_progress" <%= request.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
              <option value="complete" <%= request.status === 'complete' ? 'selected' : '' %>>Complete</option>
            </select>
          </div>
          <div class="form-group">
            <label>Admin Notes</label>
            <textarea name="admin_notes" class="form-control" rows="3"><%= request.admin_notes || '' %></textarea>
          </div>
          <button type="submit" class="btn btn-sm" style="background:var(--green);color:white;width:100%;padding:10px 20px">Update Status</button>
        </form>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/foot') %>
