<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#00d4ff">
  <title><%= title %> — Vivid Views</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #050d1a;
      --card-bg: rgba(255,255,255,0.04);
      --card-border: rgba(255,255,255,0.08);
      --cyan: #00d4ff;
      --purple: #7c3aed;
      --gradient: linear-gradient(135deg, #00d4ff, #7c3aed);
      --text: #f0f6ff;
      --text-secondary: #64748b;
      --sidebar-bg: rgba(5,13,26,0.95);
      --sidebar-border: rgba(255,255,255,0.06);
      --row-sep: rgba(255,255,255,0.04);
      --hover-row: rgba(0,212,255,0.04);
      --glow: 0 0 30px rgba(0,212,255,0.08);
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
    }

    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background-image:
        linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      z-index: 0;
    }

    .sidebar {
      width: 260px;
      background: var(--sidebar-bg);
      backdrop-filter: blur(20px);
      border-right: 1px solid var(--sidebar-border);
      min-height: 100vh;
      position: fixed;
      top: 0; left: 0;
      z-index: 100;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
    }

    .sidebar-brand {
      padding: 24px 20px;
      border-bottom: 1px solid var(--sidebar-border);
      display: flex; align-items: center; gap: 12px;
    }

    .sidebar-monogram {
      width: 40px; height: 40px;
      background: var(--gradient);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 16px; color: #fff;
      box-shadow: 0 0 20px rgba(0,212,255,0.3);
    }

    .sidebar-brand-text h1 { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -0.5px; }
    .sidebar-brand-text small { display: block; font-size: 11px; color: var(--cyan); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }

    .sidebar-nav { flex: 1; padding: 16px 12px; }

    .sidebar-nav a {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px; color: var(--text-secondary); text-decoration: none;
      border-radius: 8px; font-size: 14px; font-weight: 500;
      transition: all 0.2s; margin-bottom: 2px;
      border-left: 3px solid transparent;
    }

    .sidebar-nav a:hover { background: rgba(0,212,255,0.05); color: var(--text); }

    .sidebar-nav a.active {
      background: rgba(0,212,255,0.08); color: var(--cyan);
      border-left-color: var(--cyan);
      box-shadow: inset 0 0 20px rgba(0,212,255,0.05);
    }

    .sidebar-nav .nav-icon { width: 20px; text-align: center; font-size: 16px; }

    .sidebar-footer {
      padding: 16px 20px;
      border-top: 1px solid var(--sidebar-border);
      display: flex; align-items: center; gap: 12px;
    }

    .user-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--gradient); display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 14px; color: #fff; flex-shrink: 0;
    }

    .sidebar-footer .user-info { flex: 1; min-width: 0; }
    .sidebar-footer .user-info strong { color: var(--text); display: block; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar-footer .user-info span { font-size: 11px; color: var(--text-secondary); }

    .btn-logout {
      background: none; border: 1px solid rgba(255,255,255,0.1);
      color: var(--text-secondary); padding: 6px 12px; border-radius: 6px;
      cursor: pointer; font-size: 12px; transition: all 0.2s; font-family: inherit;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.05); color: var(--text); border-color: rgba(255,255,255,0.2); }

    .main { margin-left: 260px; flex: 1; min-height: 100vh; position: relative; z-index: 1; }

    .topbar {
      background: rgba(5,13,26,0.8); backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--card-border);
      padding: 16px 32px; display: flex; align-items: center; justify-content: space-between;
    }
    .topbar h2 { font-size: 20px; font-weight: 600; color: var(--text); }

    .content { padding: 32px; }

    .hamburger { display: none; background: none; border: none; font-size: 24px; cursor: pointer; color: var(--text); }

    .card {
      background: var(--card-bg); backdrop-filter: blur(20px);
      border-radius: 12px; border: 1px solid var(--card-border);
      overflow: hidden; margin-bottom: 24px; box-shadow: var(--glow);
    }
    .card-header {
      padding: 16px 20px; border-bottom: 1px solid var(--card-border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-header h3 { font-size: 16px; font-weight: 600; color: var(--text); }

    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 600;
      color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;
      background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--row-sep);
    }
    td { padding: 12px 16px; font-size: 14px; border-bottom: 1px solid var(--row-sep); color: var(--text); }
    tr:hover td { background: var(--hover-row); }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; }
    .badge-stock-ok { background: rgba(16,185,129,0.2); color: #10b981; box-shadow: 0 0 8px rgba(16,185,129,0.2); }
    .badge-stock-low { background: rgba(245,158,11,0.2); color: #fbbf24; box-shadow: 0 0 8px rgba(245,158,11,0.2); animation: pulse-amber 2s infinite; }
    .badge-stock-out { background: rgba(239,68,68,0.2); color: #ef4444; box-shadow: 0 0 8px rgba(239,68,68,0.3); animation: pulse-red 2s infinite; }

    .badge-add { background: rgba(16,185,129,0.15); color: #10b981; }
    .badge-use { background: rgba(0,212,255,0.15); color: #00d4ff; }
    .badge-adjust { background: rgba(245,158,11,0.15); color: #fbbf24; }
    .badge-remove { background: rgba(239,68,68,0.15); color: #ef4444; }

    @keyframes pulse-amber { 0%,100%{box-shadow:0 0 8px rgba(245,158,11,0.2);} 50%{box-shadow:0 0 16px rgba(245,158,11,0.5);} }
    @keyframes pulse-red { 0%, 100% { box-shadow: 0 0 8px rgba(239,68,68,0.2); } 50% { box-shadow: 0 0 16px rgba(239,68,68,0.4); } }

    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 600;
      text-decoration: none; border: none; cursor: pointer;
      transition: all 0.2s; font-family: inherit;
    }
    .btn:hover { transform: translateY(-1px); }

    .btn-primary { background: var(--gradient); color: #fff; box-shadow: 0 0 20px rgba(0,212,255,0.15); }
    .btn-primary:hover { box-shadow: 0 0 30px rgba(0,212,255,0.3); }

    .btn-secondary { background: var(--card-bg); color: var(--cyan); border: 1px solid rgba(0,212,255,0.3); }
    .btn-secondary:hover { background: rgba(0,212,255,0.08); border-color: var(--cyan); }

    .btn-sm { padding: 6px 12px; font-size: 13px; }

    .btn-use {
      background: rgba(0,212,255,0.15); color: #00d4ff;
      border: 1px solid rgba(0,212,255,0.3);
      padding: 4px 10px; font-size: 12px; border-radius: 6px;
      cursor: pointer; font-family: inherit; font-weight: 600; transition: all 0.2s;
    }
    .btn-use:hover { background: rgba(0,212,255,0.25); }

    .btn-adjust {
      background: rgba(100,116,139,0.15); color: #94a3b8;
      border: 1px solid rgba(100,116,139,0.3);
      padding: 4px 10px; font-size: 12px; border-radius: 6px;
      cursor: pointer; font-family: inherit; font-weight: 600; transition: all 0.2s;
    }
    .btn-adjust:hover { background: rgba(100,116,139,0.25); }

    .btn-del {
      background: rgba(239,68,68,0.15); color: #ef4444;
      border: 1px solid rgba(239,68,68,0.3);
      padding: 4px 10px; font-size: 12px; border-radius: 6px;
      cursor: pointer; font-family: inherit; font-weight: 600; transition: all 0.2s;
    }
    .btn-del:hover { background: rgba(239,68,68,0.25); }

    .form-control {
      width: 100%; padding: 10px 14px;
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; font-size: 14px; font-family: inherit;
      color: var(--text); transition: all 0.2s;
    }
    .form-control:focus { outline: none; border-color: var(--cyan); box-shadow: 0 0 12px rgba(0,212,255,0.15); }

    .empty-state { text-align: center; padding: 48px 20px; color: var(--text-secondary); }
    .empty-state .icon { font-size: 48px; margin-bottom: 12px; }
    .empty-state p { font-size: 16px; }

    .qty-big { font-size: 22px; font-weight: 700; }

    details summary { cursor: pointer; list-style: none; }
    details summary::-webkit-details-marker { display: none; }

    .adjust-form { display: inline-flex; gap: 6px; align-items: center; margin-top: 6px; }
    .adjust-form input {
      padding: 4px 8px; width: 70px; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px; font-size: 13px; font-family: inherit;
      background: rgba(255,255,255,0.05); color: var(--text);
    }
    .adjust-form input:focus { outline: none; border-color: var(--cyan); }
    .adjust-form input[name="note"] { width: 120px; }

    .add-form-grid {
      display: grid; grid-template-columns: 2fr 2fr 1fr 1fr 1fr auto; gap: 8px; align-items: end;
      padding: 16px 20px;
    }
    .add-form-grid label { font-size: 11px; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; display: block; }
    .add-form-grid input {
      width: 100%; padding: 8px 10px; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px; font-size: 13px; font-family: inherit;
      background: rgba(255,255,255,0.05); color: var(--text);
    }
    .add-form-grid input:focus { outline: none; border-color: var(--cyan); }

    .actions-cell { display: flex; gap: 4px; align-items: center; flex-wrap: wrap; }

    .cmd-overlay {
      display: none; position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
      align-items: flex-start; justify-content: center; padding-top: 20vh;
    }
    .cmd-overlay.active { display: flex; }
    .cmd-palette {
      width: 500px; max-width: 90vw;
      background: rgba(10,22,40,0.95); backdrop-filter: blur(20px);
      border: 1px solid var(--card-border); border-radius: 12px;
      box-shadow: 0 0 60px rgba(0,212,255,0.15);
      transform: scale(0.95); opacity: 0; transition: all 0.15s ease;
    }
    .cmd-overlay.active .cmd-palette { transform: scale(1); opacity: 1; }
    .cmd-input {
      width: 100%; padding: 16px 20px; background: transparent;
      border: none; border-bottom: 1px solid var(--card-border);
      font-size: 16px; color: var(--text); font-family: inherit; outline: none;
    }
    .cmd-input::placeholder { color: var(--text-secondary); }
    .cmd-results { padding: 8px; max-height: 300px; overflow-y: auto; }
    .cmd-item {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px; border-radius: 8px; cursor: pointer;
      color: var(--text-secondary); font-size: 14px; transition: all 0.1s;
    }
    .cmd-item:hover, .cmd-item.active { background: rgba(0,212,255,0.08); color: var(--cyan); }
    .cmd-item .cmd-icon { font-size: 18px; width: 24px; text-align: center; }
    .cmd-hint { padding: 8px 16px; border-top: 1px solid var(--card-border); font-size: 11px; color: var(--text-secondary); text-align: center; }

    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: block; }
      .content { padding: 16px; }
      table { font-size: 13px; }
      th, td { padding: 8px 10px; }
      .add-form-grid { grid-template-columns: 1fr 1fr; }
    }

    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; }
    .overlay.active { display: block; }
      @media (max-width: 768px) {
      .card { overflow-x: auto; }
      .content { padding: 12px; padding-bottom: 20px; }
      .quick-actions { flex-direction: column; }
      .detail-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

<% var active = 'inventory'; %>
<nav class="sidebar">
  <div class="sidebar-brand">
    <div class="sidebar-monogram">VV</div>
    <div class="sidebar-brand-text">
      <h1>Vivid Views</h1>
      <small>Admin Portal</small>
    </div>
  </div>
  <div class="sidebar-nav">
    <a href="/admin" class="<%= active === 'dashboard' ? 'active' : '' %>"><span class="nav-icon">📊</span> Dashboard</a>
    <a href="/admin/clients" class="<%= active === 'clients' ? 'active' : '' %>"><span class="nav-icon">🏢</span> Clients</a>
    <a href="/admin/requests" class="<%= active === 'requests' ? 'active' : '' %>"><span class="nav-icon">📋</span> Requests</a>
    <a href="/admin/employees" class="<%= active === 'employees' ? 'active' : '' %>"><span class="nav-icon">👥</span> Employees</a>
    <a href="/admin/emergency" class="<%= active === 'emergency' ? 'active' : '' %>" style="position:relative">
      <span class="nav-icon">⚠️</span> Emergency
    </a>
    <a href="/admin/inventory" class="<%= active === 'inventory' ? 'active' : '' %>"><span class="nav-icon">📦</span> Inventory</a>
    <a href="/admin/revenue" class="<%= active === 'revenue' ? 'active' : '' %>"><span class="nav-icon">💰</span> Revenue</a>
    <a href="/admin/announcements" class="<%= active === 'announcements' ? 'active' : '' %>"><span class="nav-icon">📢</span> Announcements</a>
    <a href="/admin/settings" class="<%= active === 'settings' ? 'active' : '' %>"><span class="nav-icon">⚙️</span> Settings</a>
  </div>
  <div class="sidebar-footer">
    <div class="user-avatar"><%= user.name ? user.name.charAt(0).toUpperCase() : 'A' %></div>
    <div class="user-info">
      <strong><%= user.name %></strong>
      <span>Admin</span>
    </div>
    <form method="POST" action="/auth/logout" style="margin:0">
      <button type="submit" class="btn-logout">↗</button>
    </form>
  </div>
</nav>

<!-- Command Palette -->
<div class="cmd-overlay" id="cmdPalette">
  <div class="cmd-palette">
    <input type="text" class="cmd-input" id="cmdInput" placeholder="Search commands..." autocomplete="off">
    <div class="cmd-results" id="cmdResults"></div>
    <div class="cmd-hint">↑↓ Navigate · Enter Select · Esc Close</div>
  </div>
</div>

<script>
(function() {
  const commands = [
    { icon: '📊', label: 'Dashboard', url: '/admin' },
    { icon: '🏢', label: 'All Clients', url: '/admin/clients' },
    { icon: '📋', label: 'All Requests', url: '/admin/requests' },
    { icon: '👥', label: 'Employees', url: '/admin/employees' },
    { icon: '⚠️', label: 'Emergency Queue', url: '/admin/emergency' },
    { icon: '📦', label: 'Inventory', url: '/admin/inventory' },
    { icon: '💰', label: 'Revenue', url: '/admin/revenue' },
    { icon: '⚙️', label: 'Settings', url: '/admin/settings' },
  ];

  const overlay = document.getElementById('cmdPalette');
  const input = document.getElementById('cmdInput');
  const results = document.getElementById('cmdResults');
  let activeIdx = 0;

  function render(filter) {
    const filtered = filter ? commands.filter(c => c.label.toLowerCase().includes(filter.toLowerCase())) : commands;
    activeIdx = 0;
    results.innerHTML = filtered.map((c, i) =>
      `<div class="cmd-item ${i === 0 ? 'active' : ''}" data-url="${c.url}"><span class="cmd-icon">${c.icon}</span> ${c.label}</div>`
    ).join('');
    results.querySelectorAll('.cmd-item').forEach((el, i) => {
      el.addEventListener('click', () => { window.location.href = el.dataset.url; });
      el.addEventListener('mouseenter', () => {
        results.querySelectorAll('.cmd-item').forEach(e => e.classList.remove('active'));
        el.classList.add('active'); activeIdx = i;
      });
    });
  }

  function open() { overlay.classList.add('active'); input.value = ''; render(''); input.focus(); }
  function close() { overlay.classList.remove('active'); }

  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); open(); return; }
    if (!overlay.classList.contains('active')) return;
    if (e.key === 'Escape') { close(); return; }
    const items = results.querySelectorAll('.cmd-item');
    if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = (activeIdx + 1) % items.length; }
    if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = (activeIdx - 1 + items.length) % items.length; }
    if (e.key === 'Enter' && items[activeIdx]) { window.location.href = items[activeIdx].dataset.url; return; }
    items.forEach((el, i) => el.classList.toggle('active', i === activeIdx));
  });

  input.addEventListener('input', () => render(input.value));
  overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
})();
</script>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2>📦 <%= client.company_name %> — Inventory</h2>
    <a href="/admin/inventory" class="btn btn-secondary btn-sm">← Back to All</a>
  </div>
  <div class="content">

    <!-- Items Table -->
    <div class="card">
      <div class="card-header">
        <h3>Inventory Items (<%= items.length %>)</h3>
      </div>
      <% if (items.length === 0) { %>
        <div class="empty-state">
          <div class="icon">📦</div>
          <p>No inventory items yet</p>
        </div>
      <% } else { %>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Item</th>
                <th>Description</th>
                <th>Quantity</th>
                <th>Unit</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => {
                const qty = parseInt(item.quantity) || 0;
                const threshold = parseInt(item.low_stock_threshold) || 2;
                let statusClass, statusLabel;
                if (qty === 0) { statusClass = 'badge-stock-out'; statusLabel = 'Out of Stock'; }
                else if (qty <= threshold) { statusClass = 'badge-stock-low'; statusLabel = 'Low Stock'; }
                else { statusClass = 'badge-stock-ok'; statusLabel = 'In Stock'; }
              %>
              <tr>
                <td style="font-weight:600"><%= item.item_name %></td>
                <td style="color:var(--text-secondary)"><%= item.description || '—' %></td>
                <td><span class="qty-big"><%= qty %></span></td>
                <td><%= item.unit %></td>
                <td><span class="badge <%= statusClass %>"><%= statusLabel %></span></td>
                <td>
                  <div class="actions-cell">
                    <form method="POST" action="/admin/inventory/<%= client.id %>/items/<%= item.id %>/use" style="display:inline">
                      <button type="submit" class="btn-use">Use One</button>
                    </form>
                    <button class="btn-adjust" onclick="toggleAdjust(this)">Adjust</button>
                    <button class="btn-del" onclick="deleteItem(<%= client.id %>, <%= item.id %>)">✕</button>
                  </div>
                  <div class="adjust-form" style="display:none">
                    <form method="POST" action="/admin/inventory/<%= client.id %>/items/<%= item.id %>/adjust" style="display:inline-flex;gap:6px;align-items:center">
                      <input type="number" name="quantity" value="<%= qty %>" min="0" required>
                      <input type="text" name="note" placeholder="Note...">
                      <button type="submit" class="btn-use">Save</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
      <!-- Add item form -->
      <details>
        <summary style="padding:12px 20px;font-size:13px;color:var(--cyan);cursor:pointer;font-weight:600">+ Add Item</summary>
        <form method="POST" action="/admin/inventory/<%= client.id %>/items">
          <div class="add-form-grid">
            <div>
              <label>Item Name</label>
              <input type="text" name="item_name" placeholder="e.g. Router" required>
            </div>
            <div>
              <label>Description</label>
              <input type="text" name="description" placeholder="Optional">
            </div>
            <div>
              <label>Quantity</label>
              <input type="number" name="quantity" value="0" min="0" required>
            </div>
            <div>
              <label>Unit</label>
              <input type="text" name="unit" value="units" required>
            </div>
            <div>
              <label>Low Alert</label>
              <input type="number" name="low_stock_threshold" value="2" min="0" required>
            </div>
            <div style="padding-bottom:1px">
              <button type="submit" class="btn btn-primary btn-sm">Add</button>
            </div>
          </div>
        </form>
      </details>
    </div>

    <!-- Activity Log -->
    <div class="card">
      <div class="card-header">
        <h3>📝 Recent Activity</h3>
        <span style="color:var(--text-secondary);font-size:13px">Last 20 entries</span>
      </div>
      <% if (logs.length === 0) { %>
        <div style="padding:24px;text-align:center;color:var(--text-secondary)">No activity yet</div>
      <% } else { %>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Item</th>
                <th>Change</th>
                <th>After</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(log => { %>
              <tr>
                <td style="color:var(--text-secondary);font-size:13px"><%= new Date(log.created_at).toLocaleString() %></td>
                <td style="font-weight:500"><%= log.item_name %></td>
                <td>
                  <span class="badge badge-<%= log.change_type %>">
                    <%= log.change_type %> (<%= log.quantity_change > 0 ? '+' : '' %><%= log.quantity_change %>)
                  </span>
                </td>
                <td style="font-weight:700"><%= log.quantity_after %></td>
                <td style="color:var(--text-secondary)"><%= log.note || '—' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</div>

<script>
  function toggleSidebar() {
    document.querySelector('.sidebar').classList.toggle('open');
    document.getElementById('overlay').classList.toggle('active');
  }

  function toggleAdjust(btn) {
    const form = btn.closest('td').querySelector('.adjust-form');
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
  }

  async function deleteItem(clientId, itemId) {
    if (!confirm('Delete this inventory item? This cannot be undone.')) return;
    await fetch(`/admin/inventory/${clientId}/items/${itemId}`, { method: 'DELETE' });
    window.location.reload();
  }
</script>
<script>if("serviceWorker" in navigator){navigator.serviceWorker.register("/sw.js").catch(()=>{});}</script>
</body>
</html>
