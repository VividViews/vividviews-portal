<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'clients', stats: { pendingEmergencies: 0 } }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2><%= site.site_name %></h2>
    <div style="display:flex;align-items:center;gap:12px">
      <span style="font-size:13px;color:var(--text-secondary)"><a href="/admin/clients/<%= client.id %>" style="color:var(--text-secondary);text-decoration:none"><%= client.company_name %></a> › <%= site.site_name %></span>
      <a href="/admin/clients/<%= client.id %>" class="btn btn-secondary btn-sm">← Back</a>
    </div>
  </div>
  <div class="content">
    <!-- Stat Cards -->
    <div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
      <div class="stat-card">
        <span class="stat-icon">📩</span>
        <div class="stat-label">Open</div>
        <div class="stat-value" data-countup="<%= stats.open %>">0</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">⚡</span>
        <div class="stat-label">In Progress</div>
        <div class="stat-value" data-countup="<%= stats.inProgress %>">0</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">✅</span>
        <div class="stat-label">Complete</div>
        <div class="stat-value" data-countup="<%= stats.complete %>">0</div>
      </div>
    </div>

    <div class="detail-grid">
      <div>
        <!-- Requests Table -->
        <div class="card">
          <div class="card-header"><h3>Service Requests</h3></div>
          <table>
            <thead>
              <tr><th>ID</th><th>Service</th><th>Urgency</th><th>Status</th><th>Days Open</th><th>Date</th></tr>
            </thead>
            <tbody>
              <% requests.forEach(r => {
                const daysOpen = Math.floor((Date.now() - new Date(r.created_at).getTime()) / 86400000);
              %>
              <tr style="cursor:pointer" onclick="window.location='/admin/requests/<%= r.id %>'">
                <td><a href="/admin/requests/<%= r.id %>">#<%= r.id %></a></td>
                <td><%= r.service_type_name %></td>
                <td><span class="badge badge-<%= r.urgency %>"><%= r.urgency %></span></td>
                <td><span class="badge badge-<%= r.status %>"><%= r.status.replace('_',' ') %></span></td>
                <td><%= r.status === 'complete' ? '—' : daysOpen + 'd' %></td>
                <td style="color:var(--text-secondary)"><%= new Date(r.created_at).toLocaleDateString() %></td>
              </tr>
              <% }) %>
              <% if (requests.length === 0) { %>
              <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--text-secondary)">No requests for this site</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div>
        <!-- Site Info / Edit -->
        <div class="detail-section">
          <h3>Site Information</h3>
          <form method="POST" action="/admin/clients/<%= client.id %>/sites/<%= site.id %>">
            <div class="form-group">
              <label>Site Name</label>
              <input type="text" name="site_name" class="form-control" value="<%= site.site_name %>" required>
            </div>
            <div class="form-group">
              <label>Address</label>
              <input type="text" name="address" class="form-control" value="<%= site.address || '' %>">
            </div>
            <div style="display:flex;gap:8px">
              <div class="form-group" style="flex:1">
                <label>City</label>
                <input type="text" name="city" class="form-control" value="<%= site.city || '' %>">
              </div>
              <div class="form-group" style="width:60px">
                <label>State</label>
                <input type="text" name="state" class="form-control" value="<%= site.state || '' %>" maxlength="2">
              </div>
              <div class="form-group" style="width:80px">
                <label>Zip</label>
                <input type="text" name="zip" class="form-control" value="<%= site.zip || '' %>">
              </div>
            </div>
            <div class="form-group">
              <label>Manager Name</label>
              <input type="text" name="site_manager_name" class="form-control" value="<%= site.site_manager_name || '' %>">
            </div>
            <div class="form-group">
              <label>Manager Phone</label>
              <input type="text" name="site_manager_phone" class="form-control" value="<%= site.site_manager_phone || '' %>">
            </div>
            <div class="form-group">
              <label>Manager Email</label>
              <input type="email" name="site_manager_email" class="form-control" value="<%= site.site_manager_email || '' %>">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%">Save Changes</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
