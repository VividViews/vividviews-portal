<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar-admin', { user, active: 'clients', stats: { pendingEmergencies: 0 } }) %>

<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <h2>Edit Client</h2>
    <a href="/admin/clients/<%= client.id %>" class="btn btn-secondary btn-sm">← Back</a>
  </div>
  <div class="content">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <div class="detail-section" style="max-width:600px">
      <h3>Edit <%= client.company_name %></h3>
      <form method="POST" action="/admin/clients/<%= client.id %>/edit">
        <div class="form-group">
          <label>Company Name</label>
          <input type="text" name="company_name" class="form-control" value="<%= client.company_name %>" required>
        </div>
        <div class="form-group">
          <label>Client Type</label>
          <select name="client_type_id" class="form-control">
            <option value="">— None —</option>
            <% clientTypes.forEach(ct => { %>
              <option value="<%= ct.id %>" <%= client.client_type_id === ct.id ? 'selected' : '' %>><%= ct.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Contact Name</label>
          <input type="text" name="name" class="form-control" value="<%= clientUser.name %>" required>
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" class="form-control" value="<%= clientUser.email %>" required>
        </div>
        <div class="form-group">
          <label>New Password (leave blank to keep current)</label>
          <input type="password" name="password" class="form-control" minlength="6" placeholder="••••••••">
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/admin/clients/<%= client.id %>" class="btn btn-secondary" style="margin-left:8px">Cancel</a>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
